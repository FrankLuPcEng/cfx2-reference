[
  {
    "group": "連線管理",
    "color": "#5e35b1",
    "items": [
      {
        "id": "conn",
        "label": "Endpoint 上線與能力宣告",
        "desc": "Endpoint 上線後與 MES 進行能力宣告與存活確認。",
        "badgeText": "連線",
        "badgeColor": "#5e35b1",
        "participants": [
          "BROKER",
          "ENDPOINT",
          "MES"
        ],
        "frames": [],
        "steps": [
          {
            "from": "ENDPOINT",
            "to": "BROKER",
            "msg": "connect AMQP",
            "type": "event",
            "note": "TCP/TLS 連線（非 CFX 訊息）",
            "raw": true
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.EndpointConnected",
            "type": "event",
            "note": "廣播：機台上線"
          },
          {
            "from": "MES",
            "to": "ENDPOINT",
            "msg": "CFX.AreYouThereRequest",
            "type": "request",
            "note": ""
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.AreYouThereResponse",
            "type": "response",
            "note": ""
          },
          {
            "from": "MES",
            "to": "ENDPOINT",
            "msg": "CFX.GetEndpointInformationRequest",
            "type": "request",
            "note": ""
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.GetEndpointInformationResponse",
            "type": "response",
            "note": "SupportedTopics / SupportedMessages / layout"
          },
          {
            "from": "MES",
            "to": "ENDPOINT",
            "msg": "CFX.WhoIsThereRequest",
            "type": "request",
            "note": "廣播：詢問全網在線機台"
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.WhoIsThereResponse",
            "type": "response",
            "note": ""
          }
        ]
      },
      {
        "id": "shutdown",
        "label": "Endpoint 下線通知",
        "desc": "Endpoint 關機前先廣播下線通知，再中斷 AMQP 連線。",
        "badgeText": "下線",
        "badgeColor": "#5e35b1",
        "participants": [
          "BROKER",
          "ENDPOINT",
          "MES"
        ],
        "frames": [],
        "steps": [
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.EndpointShuttingDown",
            "type": "event",
            "note": "廣播：機台即將下線"
          },
          {
            "from": "ENDPOINT",
            "to": "BROKER",
            "msg": "disconnect AMQP",
            "type": "event",
            "note": "TCP 斷線（非 CFX 訊息）",
            "raw": true
          }
        ]
      }
    ]
  },
