  {
    "group": "故障與狀態",
    "color": "#b71c1c",
    "items": [
      {
        "id": "fault",
        "label": "故障與狀態回報",
        "desc": "機台狀態、故障發生、遠端處理與現場排除的回報流程。",
        "badgeText": "Fault",
        "badgeColor": "#b71c1c",
        "participants": [
          "ENDPOINT",
          "MES",
          "OPERATOR"
        ],
        "frames": [],
        "steps": [
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.StationOnline",
            "type": "event",
            "note": "機台上線/恢復"
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.StationStateChanged",
            "type": "event",
            "note": "狀態：Production → Fault"
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.FaultOccurred",
            "type": "event",
            "note": "回報故障碼與嚴重程度"
          },
          {
            "from": "MES",
            "to": "ENDPOINT",
            "msg": "CFX.ResourcePerformance.HandleFaultRequest",
            "type": "request",
            "note": "要求機台遠端處理"
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.HandleFaultResponse",
            "type": "response",
            "note": ""
          },
          {
            "from": "OPERATOR",
            "to": "ENDPOINT",
            "msg": "acknowledge / clear locally",
            "type": "event",
            "note": "操作員本機確認/排除（非 CFX 訊息）",
            "raw": true
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.FaultAcknowledged",
            "type": "event",
            "note": "已確認"
          },
          {
            "from": "ENDPOINT",
            "to": "MES",
            "msg": "CFX.ResourcePerformance.FaultCleared",
            "type": "event",
            "note": "故障已排除"
          }
        ]
      }
    ]
  },
