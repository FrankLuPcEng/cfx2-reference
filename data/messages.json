    "schema": "{\n  \"TransactionId\": \"ce1cf002-50fe-4cd4\",\n  \"InstalledMaterials\": [\n    {\n      \"UnitIdentifier\": \"PCB-SN-0042\",\n      \"UnitPositionNumber\": 1,\n      \"QuantityInstalled\": 3,\n      \"Material\": {\n        \"UniqueIdentifier\": \"REEL-7890\",\n        \"PartNumber\": \"CAP-0402\"\n      }\n    }\n  ]\n}",
    "fields": [
