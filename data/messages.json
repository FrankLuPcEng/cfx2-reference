  "CFX.Production.Processing.UnitsProcessed": {
    "dir": "event",
    "module": "CFX.Production.Processing",
    "desc": "一般製程加工（回焊、焊接、塗佈、清洗、打碼）完成後發布，使用動態子結構（CommonProcessData）記錄製程參數。",
    "schema": "{\n  \"TransactionId\": \"a881ac27-9649\",\n  \"OverallResult\": \"Succeeded\",\n  \"CommonProcessData\": {\n    \"$type\": \"CFX.Structures.SolderReflow.ReflowProcessData, CFX\",\n    \"ConveyorSpeed\": 60\n  },\n  \"UnitProcessResults\": [\n    {\n      \"UnitIdentifier\": \"PCB-SN-0042\",\n      \"UnitResult\": \"Succeeded\"\n    }\n  ]\n}",
    "fields": [
      {
        "name": "TransactionId",
        "type": "UUID",
        "req": true,
        "desc": "交易識別碼"
      },
      {
        "name": "OverallResult",
        "type": "enum",
        "req": true,
        "desc": "Succeeded | Failed"
      },
      {
        "name": "CommonProcessData.$type",
        "type": "string",
        "req": true,
        "desc": "動態子結構型別名稱—決定製程類型"
      },
      {
        "name": "UnitIdentifier",
        "type": "string",
        "req": true,
        "desc": "單板序號"
      },
      {
        "name": "UnitResult",
        "type": "enum",
        "req": true,
        "desc": "Succeeded | Failed"
      }
    ],
    "notes": "CommonProcessData.$type 的值決定具體製程：ReflowProcessData（回焊）、SelectiveSolderProcessData（選擇焊）、WaveProcessData（波峰焊）、HandSolderingProcessData（手焊）、CoatingProcessData（塗佈）、CleaningProcessData（清洗）、LaserMarkingProcessData（雷射打碼）。"
  },
