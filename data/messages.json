  "CFX.Production.TestAndInspection.UnitsInspected": {
    "dir": "event",
    "module": "CFX.Production.TestAndInspection",
    "desc": "AOI / SPI / AXI 完成板面檢測後發布，回報量測值與缺陷清單。（正確命名空間：CFX.Production.TestAndInspection）",
    "schema": "{\n  \"TransactionId\": \"14d48338-09b7-4d20\",\n  \"InspectionMethod\": \"AOI\",\n  \"SamplingInformation\": {\n    \"SamplingMethod\": \"NoSampling\"\n  },\n  \"Units\": [\n    {\n      \"UnitIdentifier\": \"PCB-SN-0042\",\n      \"UnitResult\": \"Failed\",\n      \"Defects\": [\n        {\n          \"ReferenceDesignator\": \"R12\",\n          \"DefectCode\": \"SOLDER_BRIDGE\"\n        }\n      ]\n    }\n  ]\n}",
    "fields": [
      {
        "name": "TransactionId",
        "type": "UUID",
        "req": true,
        "desc": "交易識別碼"
      },
      {
        "name": "InspectionMethod",
        "type": "enum",
        "req": true,
        "desc": "AOI | SPI | AXI | Manual"
      },
      {
        "name": "SamplingMethod",
        "type": "enum",
        "req": false,
        "desc": "抽樣方式"
      },
      {
        "name": "UnitResult",
        "type": "enum",
        "req": true,
        "desc": "Passed | Failed | Skipped"
      },
      {
        "name": "ReferenceDesignator",
        "type": "string",
        "req": false,
        "desc": "缺陷元件位號"
      },
      {
        "name": "DefectCode",
        "type": "string",
        "req": true,
        "desc": "缺陷代碼"
      }
