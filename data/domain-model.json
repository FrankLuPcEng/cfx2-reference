  "linkageRules": [
    {
      "id": "LR01",
      "title": "WorkSession 生命週期",
      "desc": "WorkStarted 建立 WorkSession（transactionId = PK）。WorkCompleted（同 transactionId）關閉 WorkSession，記錄 endTime 與 cycleTime。若 FaultOccurred 後無 WorkCompleted，WorkSession 保持 isOpen=true，由 MES 超時機制處理。StationOffline 觸發所有 isOpen WorkSession 異常關閉。"
    },
    {
      "id": "LR02",
      "title": "物料追溯鏈",
      "desc": "ComponentsPlaced / MaterialsInstalled 訊息中同時含 Units[].UniqueIdentifier 與 InstalledMaterials[].MaterialIdentifier，建立 MaterialConsumption 記錄。追溯路徑：Unit → MaterialConsumption → MaterialCarrier → PartNumber / ManufacturerLot"
    },
    {
      "id": "LR03",
      "title": "InspectionResult 多站累積",
      "desc": "一個 Unit 在 SPI → AOI → ICT 各站各產生一筆 InspectionResult。可透過 Unit.uniqueIdentifier 彙整所有站點的判定記錄，計算最終良率。WorkOrderActionExecuted 用於人工 ACCEPT/REJECT 覆蓋，需設 isOverridden=true。"
    },
    {
      "id": "LR04",
      "title": "OEE 計算基礎",
      "desc": "可用率 = Σ(StationStateEvent where newState=Running).duration / 總觀察時間。效率率 = 標準 CycleTime / WorkSession.cycleTime 平均值。品質率 = Pass 的 InspectionResult 數 / 總 Unit 數。時間重疊：FaultEvent.{startTime,endTime} ∩ WorkSession.{startTime,endTime} = 故障導致的生產中斷時間。"
    },
    {
      "id": "LR05",
      "title": "Recipe 與 WorkSession 串聯",
      "desc": "RecipeActivated 更新 Machine.currentRecipe。WorkStarted.RecipeName 直接記錄到 WorkSession.recipeName（Phase 1-3 作字串儲存）。Phase 4 升格後，WorkSession.recipeName + recipeVersion 作為 FK 指向 Recipe Entity。"
    }
  ]
}
